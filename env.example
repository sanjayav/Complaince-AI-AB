# AI CORE RAG API Service Environment Configuration
# Copy this file to .env and fill in your actual values

# Application
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jlrdi

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
SECRET_KEY=your-secret-key-change-in-production

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
S3_PREFIX=ocr_stage/

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=1000
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_EMBEDDING_DIMENSIONS=1536

# Qdrant Configuration (Your Instance)
QDRANT_URL=http://54.165.214.100:6333/
QDRANT_API_KEY=AI_CORE
QDRANT_COLLECTION_PREFIX=jlrdi_
QDRANT_TIMEOUT=30
QDRANT_MAX_RETRIES=3

# Analytics Configuration
MAX_LOGGED_REQUESTS=10000

# CORS Origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://localhost:8080","https://*.ngrok-free.app","https://*.ngrok.io","*"]
