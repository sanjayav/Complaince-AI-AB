# JLR Document Intelligence Backend Environment Configuration
# Copy this to .env and update with your actual values

# Application Settings
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database (Update with your colleague's database details)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jlrdi?sslmode=disable

# JWT Authentication
JWT_SECRET_KEY=devsecret123
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS S3 (Your actual credentials - replace with your values)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=jlr-doc-intel-bucket-us
S3_PREFIX=ocr_stage/

# OpenAI (Get your key from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Security
SECRET_KEY=devsecret123

# CORS (Frontend URLs)
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8080"]
