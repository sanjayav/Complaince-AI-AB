pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = 'jlr-doc-intel'
        DOCKER_TAG = "${env.BUILD_NUMBER}"
        REGISTRY = 'your-registry.com'
        AWS_REGION = 'us-east-1'
        S3_BUCKET = 'jlr-doc-intel-bucket-us'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'pip install -r requirements.txt'
                        sh 'pip install pytest pytest-cov black flake8'
                    } else {
                        bat 'pip install -r requirements.txt'
                        bat 'pip install pytest pytest-cov black flake8'
                    }
                }
            }
        }
        
        stage('Code Quality') {
            parallel {
                stage('Lint') {
                    steps {
                        script {
                            if (isUnix()) {
                                sh 'black --check app/'
                                sh 'flake8 app/ --max-line-length=88 --ignore=E203,W503'
                            } else {
                                bat 'black --check app/'
                                bat 'flake8 app/ --max-line-length=88 --ignore=E203,W503'
                            }
                        }
                    }
                }
                
                stage('Security Scan') {
                    steps {
                        script {
                            if (isUnix()) {
                                sh 'pip install safety'
                                sh 'safety check'
                            } else {
                                bat 'pip install safety'
                                bat 'safety check'
                            }
                        }
                    }
                }
            }
        }
        
        stage('Unit Tests') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'pytest app/ --cov=app --cov-report=xml --cov-report=html'
                    } else {
                        bat 'pytest app/ --cov=app --cov-report=xml --cov-report=html'
                    }
                }
            }
            post {
                always {
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'htmlcov',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ])
                    publishCoverage adapters: [coberturaAdapter('coverage.xml')], sourceFileResolver: sourceFiles('STORE_LAST_BUILD')
                }
            }
        }
        
        stage('Integration Tests') {
            steps {
                script {
                    // Start test database and run integration tests
                    if (isUnix()) {
                        sh 'docker compose -f docker-compose.test.yml up -d'
                        sh 'sleep 30'  // Wait for services to be ready
                        sh 'pytest tests/integration/ -v'
                    } else {
                        bat 'docker compose -f docker-compose.test.yml up -d'
                        bat 'timeout /t 30'  // Wait for services to be ready
                        bat 'pytest tests/integration/ -v'
                    }
                }
            }
            post {
                always {
                    script {
                        if (isUnix()) {
                            sh 'docker compose -f docker-compose.test.yml down'
                        } else {
                            bat 'docker compose -f docker-compose.test.yml down'
                        }
                    }
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    if (isUnix()) {
                        sh "docker build -f Dockerfile.python -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                        sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
                    } else {
                        bat "docker build -f Dockerfile.python -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                        bat "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
                    }
                }
            }
        }
        
        stage('Push to Registry') {
            when {
                branch 'main'
            }
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker-registry', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        if (isUnix()) {
                            sh "docker login ${REGISTRY} -u ${DOCKER_USER} -p ${DOCKER_PASS}"
                            sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${REGISTRY}/${DOCKER_IMAGE}:${DOCKER_TAG}"
                            sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${REGISTRY}/${DOCKER_IMAGE}:latest"
                            sh "docker push ${REGISTRY}/${DOCKER_IMAGE}:${DOCKER_TAG}"
                            sh "docker push ${REGISTRY}/${DOCKER_IMAGE}:latest"
                        } else {
                            bat "docker login ${REGISTRY} -u ${DOCKER_USER} -p ${DOCKER_PASS}"
                            bat "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${REGISTRY}/${DOCKER_IMAGE}:${DOCKER_TAG}"
                            bat "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${REGISTRY}/${DOCKER_IMAGE}:latest"
                            bat "docker push ${REGISTRY}/${DOCKER_IMAGE}:${DOCKER_TAG}"
                            bat "docker push ${REGISTRY}/${DOCKER_IMAGE}:latest"
                        }
                    }
                }
            }
        }
        
        stage('Deploy to Staging') {
            when {
                branch 'main'
            }
            steps {
                script {
                    // Deploy to staging environment
                    if (isUnix()) {
                        sh 'ssh user@staging-server "cd /opt/jlr-backend && docker compose pull && docker compose up -d"'
                    } else {
                        bat 'ssh user@staging-server "cd /opt/jlr-backend && docker compose pull && docker compose up -d"'
                    }
                }
            }
        }
        
        stage('Deploy to Production') {
            when {
                branch 'main'
            }
            input {
                message "Deploy to production?"
                ok "Deploy"
            }
            steps {
                script {
                    // Deploy to production environment
                    if (isUnix()) {
                        sh 'ssh user@prod-server "cd /opt/jlr-backend && docker compose pull && docker compose up -d"'
                    } else {
                        bat 'ssh user@prod-server "cd /opt/jlr-backend && docker compose pull && docker compose up -d"'
                    }
                }
            }
        }
    }
    
    post {
        always {
            // Cleanup
            script {
                if (isUnix()) {
                    sh 'docker system prune -f'
                } else {
                    bat 'docker system prune -f'
                }
            }
        }
        
        success {
            // Notify success
            emailext (
                subject: "Build Successful: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build ${env.BUILD_NUMBER} completed successfully. View details: ${env.BUILD_URL}",
                to: "team@jlr.com"
            )
        }
        
        failure {
            // Notify failure
            emailext (
                subject: "Build Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build ${env.BUILD_NUMBER} failed. View details: ${env.BUILD_URL}",
                to: "team@jlr.com"
            )
        }
    }
}
