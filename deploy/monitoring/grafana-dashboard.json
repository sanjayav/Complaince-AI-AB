{
  "dashboard": {
    "id": null,
    "title": "JLR Document Intelligence - Production Dashboard",
    "tags": ["jlrdi", "automotive", "production"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"jlrdi-api\"}",
            "legendFormat": "API Status"
          },
          {
            "expr": "up{job=\"jlrdi-qdrant\"}",
            "legendFormat": "Qdrant Status"
          },
          {
            "expr": "up{job=\"postgres\"}",
            "legendFormat": "Database Status"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{route}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 3,
        "title": "Response Time (95th Percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{route}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
            "legendFormat": "{{route}} - {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 5,
        "title": "PDF Processing Queue",
        "type": "graph",
        "targets": [
          {
            "expr": "jlrdi_pdf_processing_queue_size",
            "legendFormat": "Queue Size"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 6,
        "title": "Worker Pool Status",
        "type": "stat",
        "targets": [
          {
            "expr": "jlrdi_worker_pool_active_workers",
            "legendFormat": "Active Workers"
          },
          {
            "expr": "jlrdi_worker_pool_total_workers",
            "legendFormat": "Total Workers"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 7,
        "title": "PDF Processing Duration",
        "type": "histogram",
        "targets": [
          {
            "expr": "rate(jlrdi_pdf_processing_duration_seconds_bucket[5m])",
            "legendFormat": "{{le}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 8,
        "title": "Database Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "pg_stat_database_numbackends",
            "legendFormat": "Active Connections"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}
      },
      {
        "id": 9,
        "title": "Qdrant Collection Size",
        "type": "graph",
        "targets": [
          {
            "expr": "qdrant_collections_points_total",
            "legendFormat": "{{collection}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
      },
      {
        "id": 10,
        "title": "S3 Operations",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(s3_operations_total[5m])",
            "legendFormat": "{{operation}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40}
      },
      {
        "id": 11,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "container_memory_usage_bytes{container=\"api\"}",
            "legendFormat": "API Memory"
          },
          {
            "expr": "container_memory_usage_bytes{container=\"qdrant\"}",
            "legendFormat": "Qdrant Memory"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 48}
      },
      {
        "id": 12,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{container=\"api\"}[5m])",
            "legendFormat": "API CPU"
          },
          {
            "expr": "rate(container_cpu_usage_seconds_total{container=\"qdrant\"}[5m])",
            "legendFormat": "Qdrant CPU"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "10s"
  }
}
